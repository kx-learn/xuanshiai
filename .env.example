# ==================== 应用基础配置 ====================
# 应用名称，会显示在 OpenAPI 文档和根路径响应中。
APP_NAME=Xuanshi AI API
# 当前版本号，发布时请同步修改。
APP_VERSION=0.1.0
# 可选值：development、testing、staging、production。
ENVIRONMENT=development
# 开发环境开启调试；生产环境必须改为 false。
DEBUG=true
# 是否暴露 /docs 和 /redoc；生产环境可按安全策略关闭。
DOCS_ENABLED=true
# 监听地址。容器部署通常使用 0.0.0.0，本机开发使用 127.0.0.1。
HOST=127.0.0.1
# FastAPI/Uvicorn 服务端口。
PORT=8000
# API 统一前缀，后续业务接口都挂在该路径下。
API_PREFIX=/api/v1
# 开发/测试环境启动时自动创建数据库和表；staging/production 必须设为 false。
AUTO_INIT_DB=true

# ==================== 数据库与缓存 ====================
# MySQL 异步连接串；请替换用户名、密码、主机、端口和数据库名。
DATABASE_URL=mysql+aiomysql://root:YOUR_MYSQL_PASSWORD@127.0.0.1:3306/xuanshiai
# Redis 连接串；用于缓存、限流、验证码和异步任务状态等。
REDIS_URL=redis://127.0.0.1:6379/0

# ==================== 登录与安全 ====================
# JWT 签名密钥；生产环境必须使用高强度随机字符串，禁止提交真实密钥。
SECRET_KEY=change-me-in-local-env
# JWT 签名算法。
JWT_ALGORITHM=HS256
# 访问令牌有效期，单位为分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh Token 有效期和单账号最多有效设备数。
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_SESSIONS_PER_USER=5
# 验证码策略；短信服务接入后将 SMS_PROVIDER 替换为实际适配器名称。
SMS_CODE_EXPIRE_SECONDS=300
SMS_SEND_INTERVAL_SECONDS=60
SMS_DAILY_LIMIT=10
# 可选值：disabled、mock；真实供应商适配器接入后再填写对应名称。
SMS_PROVIDER=disabled
# 仅 development/testing 环境可使用 mock，固定测试验证码为123456。
SMS_MOCK_CODE=123456
# 微信小程序配置，接入微信登录前必须填写真实值。
WECHAT_PROVIDER=wechat
WECHAT_APP_ID=YOUR_WECHAT_APP_ID
WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET
# Mock 微信凭证格式为 mock-code-001，仅允许 development/testing 环境。
WECHAT_MOCK_OPENID_PREFIX=mock-openid-
# 当前发布的协议版本，格式为 agreement_type:version，多个用逗号分隔。
AGREEMENT_VERSIONS_RAW=user_service:v1,privacy_policy:v1,safety_pledge:v1,community_rules:v1

# ==================== 跨域、文件与日志 ====================
# 多个来源使用英文逗号分隔，不要在生产环境使用 *。
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173
# 用户上传文件的本地存储目录；生产环境可替换为对象存储挂载目录。
UPLOAD_DIR=storage/uploads
PUBLIC_BASE_URL=http://127.0.0.1:8000
WECHAT_MINI_PROGRAM_PAGE=pages/profile/profile

# Discovery quotas. Keep these values server-side; do not accept them from clients.
RECOMMENDATION_PAGE_SIZE=20
BROWSE_DAILY_LIMIT=20
BROWSE_HIGH_MATCH_BONUS=5
APPLY_DAILY_FREE_LIMIT=3
APPLY_DAILY_VIP_LIMIT=10
SUPERLIKE_DAILY_FREE_LIMIT=1
SUPERLIKE_DAILY_VIP_LIMIT=3
# 牵线服务首次创建次数账户时的默认次数；正式规则应改为配置中心或后台规则。
MATCHMAKER_SERVICE_DEFAULT_QUOTA=3

# ==================== 会员价格与积分配置 ====================
# 会员价格覆盖数据库套餐配置，单位为元；未设置时使用数据库值。
# MEMBERSHIP_MONTHLY_PRICE=99
# MEMBERSHIP_QUARTERLY_PRICE=269
# MEMBERSHIP_YEARLY_PRICE=899
# MEMBERSHIP_MONTHLY_ORIGINAL_PRICE=129
# MEMBERSHIP_QUARTERLY_ORIGINAL_PRICE=329
# MEMBERSHIP_YEARLY_ORIGINAL_PRICE=1099
# MEMBERSHIP_MONTHLY_DAILY_PRICE=3.30
# MEMBERSHIP_QUARTERLY_DAILY_PRICE=2.99
# MEMBERSHIP_YEARLY_DAILY_PRICE=2.46

# 积分奖励配置，单位为分。
POINT_CHECKIN_REWARD=5
POINT_PROFILE_COMPLETE_REWARD=50
POINT_REALNAME_VERIFIED_REWARD=100

# 积分商品每次消耗配置，设置后覆盖 config_point_product.points_cost。
# 商品名称、库存、上下架和权益内容仍由数据库配置。
# POINT_COST_EXTRA_APPLY=20
# POINT_COST_EXTRA_SUPERLIKE=50
# POINT_COST_BROWSE_UNLOCK=10
# POINT_COST_EXPOSURE_CARD=100
# POINT_COST_PAPER_PLANE_UNLOCK=30
# POINT_COST_PROFILE_DETAIL_UNLOCK=10
# POINT_COST_MEMBERSHIP_EXCHANGE=1000
# POINT_COST_SERVICE_COUPON=500
# 日志级别，可选 DEBUG、INFO、WARNING、ERROR。
LOG_LEVEL=INFO
